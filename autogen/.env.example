# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# ── Langfuse (must match LANGFUSE_INIT_* in docker-compose) ───────
LANGFUSE_PUBLIC_KEY=pk-lf-local-dev
LANGFUSE_SECRET_KEY=sk-lf-local-dev
# Use http://langfuse:3000 inside Docker; http://localhost:3000 outside
LANGFUSE_BASE_URL=http://localhost:3000

# ── Application ───────────────────────────────────────────────────
ENVIRONMENT=development
GRADIO_SERVER_PORT=7860
GRADIO_SERVER_NAME=0.0.0.0

# ── Langfuse Self-Hosted Bootstrap (used by docker-compose) ───────
LANGFUSE_INIT_USER_EMAIL=admin@localhost.dev
LANGFUSE_INIT_USER_PASSWORD=changeme-admin-password
NEXTAUTH_SECRET=changeme-nextauth-secret-32chars
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=changeme-run-openssl-rand-hex-32
